      "sourceType": "com.cloud.common.jwt.JwtProperties",
      "defaultValue": "cloud-project-default-secret-key-please-change-in-nacos-32bytes"
    },
    {
      "name": "jwt.token-prefix",
      "type": "java.lang.String",
